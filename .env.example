# Copy to .env. One free-model API key is enough; adding more enables automatic fallback.
# Recommended first: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VERIFY_MODEL=openai/gpt-oss-120b

# Optional free-tier fallback: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_VERIFY_MODEL=gemini-2.5-flash

# Optional free-router fallback: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

LLM_PROVIDER_ORDER=groq,gemini,openrouter
COUNTYWATCH_LLM_ENABLED=true
COUNTYWATCH_LLM_MAX_CALLS_PER_RUN=450
COUNTYWATCH_VERIFY_HIGH_RISK=true

# Crawler behavior. Set a contact email so site administrators can reach you.
COUNTYWATCH_CONTACT_EMAIL=
COUNTYWATCH_CONCURRENCY=8
COUNTYWATCH_HOST_DELAY_SECONDS=1.2
COUNTYWATCH_REQUEST_TIMEOUT_SECONDS=35
COUNTYWATCH_MAX_DOCUMENT_BYTES=40000000
COUNTYWATCH_MAX_DOCUMENTS_PER_SOURCE=80
COUNTYWATCH_MAX_DOCUMENTS_PER_COUNTY=160
COUNTYWATCH_INITIAL_LOOKBACK_DAYS=730
# 0 means unlimited locally. GitHub Actions sets 300 to leave time to save/deploy.
COUNTYWATCH_MAX_RUN_MINUTES=0
COUNTYWATCH_DISCOVERY_REFRESH_DAYS=30
COUNTYWATCH_DIRECTORY_REFRESH_DAYS=45
COUNTYWATCH_BROWSER_FALLBACK=true
# Keep false unless you explicitly accept unverifiable TLS for a known county site.
COUNTYWATCH_ALLOW_INSECURE_TLS=false
COUNTYWATCH_OCR=true
COUNTYWATCH_MAX_OCR_PAGES=80
COUNTYWATCH_YOUTUBE_TRANSCRIPTS=true
